#!/usr/bin/env python-main
"""Serve docs directory and open in browser."""

import http.server
import os
import socketserver
import subprocess
import sys

import click


class QuietHandler(http.server.SimpleHTTPRequestHandler):
    """HTTP handler that suppresses request logging."""

    def log_message(self, format, *args):
        pass


def stop_all_servers():
    """Stop all running doc servers."""
    result = subprocess.run(
        ["pkill", "-f", "run-docs-server"],
        capture_output=True,
    )
    if result.returncode == 0:
        click.echo("Stopped all doc servers.")
    else:
        click.echo("No doc servers running.")


@click.command()
@click.option("--port", default=3000, help="Starting port (auto-increments if busy)")
@click.option("--no-browser", is_flag=True, help="Don't open browser")
@click.option("--stop-all", is_flag=True, help="Stop all running doc servers and exit")
def main(port, no_browser, stop_all):
    """Serve documentation and open in browser."""
    if stop_all:
        stop_all_servers()
        return

    docs_dir = os.path.join(os.path.dirname(os.path.dirname(__file__)), "docs")

    if not os.path.exists(docs_dir):
        click.echo(f"Error: {docs_dir} not found", err=True)
        sys.exit(1)

    os.chdir(docs_dir)

    # Disable SO_REUSEADDR to properly detect port conflicts
    socketserver.TCPServer.allow_reuse_address = False

    # Find available port by actually trying to bind
    httpd = None
    for actual_port in range(port, port + 100):
        try:
            httpd = socketserver.TCPServer(("", actual_port), QuietHandler)
            break
        except OSError:
            click.echo(f"Port {actual_port} in use, trying {actual_port + 1}...")
    else:
        click.echo("Could not find available port", err=True)
        sys.exit(1)

    if actual_port != port:
        click.echo(f"Using port {actual_port}")

    url = f"http://localhost:{actual_port}"
    click.echo(f"Serving {docs_dir}")
    click.echo(f"URL: {url}")
    click.echo("Press Ctrl+C to stop\n")

    if not no_browser:
        subprocess.run(["open", "-a", "Google Chrome", url], check=False)

    try:
        httpd.serve_forever()
    except KeyboardInterrupt:
        click.echo("\nStopped.")
    finally:
        httpd.server_close()


if __name__ == "__main__":
    main()
